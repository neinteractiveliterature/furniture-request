{
    "env": {
        "browser": true,
        "node": true,
        "es6": true,
        "jquery": true
    },
    "extends": [
        "eslint:recommended",
        "plugin:node/recommended",
        "plugin:@graphql-eslint/recommended",
        "plugin:@typescript-eslint/recommended"
    ],
    "globals": {
        "__dirname": "readonly"
    },
    "parser": "@typescript-eslint/parser",
    "plugins": [
        "promise",
        "@typescript-eslint"
    ],
    "root": true,
    "rules": {
        "no-var": "error",
        "prefer-const": "error",
        "no-console": "off",
        "no-empty-pattern": 2,
        "no-empty": "off",
        "node/no-missing-import": "off",
        "node/no-unpublished-import": "off",
        "indent": [
            "error",
            4,
            {
              "SwitchCase": 1
            }
        ],
        "linebreak-style": [
            "error",
            "unix"
        ],
        "quotes": [
            "error",
            "single"
        ],
        "semi": [
            "error",
            "always"
        ]
    },
    "overrides": [
        {
            "files": [
                "*.tsx",
                "*.ts",
                "*.jsx",
                "*.js"
            ],
            "processor": "@graphql-eslint/graphql"
        },
        {
            "files": [
                "*.graphql"
            ],
            "parser": "@graphql-eslint/eslint-plugin",
            "plugins": [
                "@graphql-eslint"
            ]
        }
    ]
}
